# Local SQLite database (regenerated by pnpm seed:fresh)
payload.db
payload-figma-boilerplate.db

dist / media
node_modules
.DS_Store
.env
.next
next-env.d.ts
.vercel

# Payload uploads + responsive sizes (regenerated every seed) — do not commit
public/media/*
!public/media/figma/
!public/media/figma/**

public/robots.txt
public/sitemap*.xml

# Playwright run artifacts — never commit
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Visual QA snapshot PNGs — local only (see references/*/.gitignore)
references/playwright/**/*
!references/playwright/**/
!references/playwright/.gitignore
!references/playwright/**/*.md

references/figma/**/*
!references/figma/**/
!references/figma/.gitignore
!references/figma/**/.gitkeep
!references/figma/**/*.md
